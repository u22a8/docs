{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "U+22A8",
  "description": "Documentation for u22a8.ai — deterministic trait-scoring models. Define a standard of judgment from examples, train, and score content over a REST API and an MCP server.",
